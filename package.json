{
  "name": "company-parser",
  "version": "1.0.0",
  "description": "MVP parser for company contacts from Google Maps, Instagram and open sources.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "worker": "tsx src/queue/workers.ts",
    "enqueue": "tsx src/index.ts",
    "admin": "tsx src/admin/server.ts",
    "export:csv": "tsx src/exporters/csvExporter.ts valid",
    "export:raw": "tsx src/exporters/csvExporter.ts raw",
    "export:all": "tsx src/exporters/csvExporter.ts all"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.1",
    "@types/express": "^5.0.6",
    "axios": "^1.7.9",
    "bullmq": "^5.34.5",
    "cheerio": "^1.0.0",
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "instagram-private-api": "^1.46.1",
    "ioredis": "^5.4.2",
    "libphonenumber-js": "^1.11.17",
    "mongoose": "^8.9.5",
    "p-queue": "^8.1.0",
    "puppeteer": "^24.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "validator": "^13.12.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/validator": "^13.12.2"
  }
}

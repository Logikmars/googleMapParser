NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/company-parser
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
DEFAULT_PHONE_REGION=UA
PUPPETEER_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=
GOOGLE_MAPS_MIN_DELAY_MS=3000
